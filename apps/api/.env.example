NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://smm:smm_dev_password@localhost:5432/social_media_manager?schema=public
JWT_ACCESS_SECRET=replace_with_a_long_random_secret

REDIS_HOST=localhost
REDIS_PORT=6379
# Hosted Redis/Render Key Value/Upstash can use this instead of host + port.
# REDIS_URL=redis://localhost:6379

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=.local-storage/media
MEDIA_RETENTION_DAYS=15

# Use STORAGE_DRIVER=minio for MinIO, Backblaze B2, or another S3-compatible service.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=social-media-manager-media
MINIO_USE_SSL=false
